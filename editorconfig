# Fodors EditorConfig
# http://EditorConfig.org
root = true

[*.{html,css,scss}]
indent_style = space
indent_size = 4
charset = utf-8

# Mustache Templates use .tmpl extension
[*.{tmpl,mustache}]
indent_style = space
indent_size = 4
charset = utf-8

[*.{js,json}]
indent_style = space
indent_size = 4
charset = utf-8

[*.php]
indent_style = space
indent_size = 4
charset = utf-8
